---
import { site, navLinks } from '../data/site';
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent"
>
  <div class="max-w-7xl mx-auto px-5 md:px-8 lg:px-12">
    <div class="flex items-center justify-between h-20 md:h-24">
      <a href="#" class="flex items-center gap-3 group">
        <img
          src="/images/logo.png"
          alt={site.name}
          class="h-10 md:h-12 w-auto transition-transform duration-300 group-hover:scale-105"
          width="180"
          height="48"
        />
      </a>

      <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-charcoal-light hover:text-sage-500 font-medium text-sm tracking-wide transition-colors duration-300 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-sage-500 after:transition-all hover:after:w-full"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="hidden lg:flex items-center gap-4">
        <a href={site.phoneLink} class="text-sage-600 font-semibold text-sm hover:text-sage-500 transition-colors">
          {site.phone}
        </a>
        <a href="#contact" class="btn-primary text-sm !py-2.5 !px-5">
          Book Appointment
        </a>
      </div>

      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-charcoal hover:text-sage-500 transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-0 top-20 bg-cream-50/98 backdrop-blur-lg transform translate-x-full transition-transform duration-500 z-40"
  >
    <nav class="flex flex-col items-center justify-center h-full gap-8 pb-20" aria-label="Mobile navigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link text-2xl font-display text-charcoal hover:text-sage-500 transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <a href={site.phoneLink} class="text-sage-600 font-semibold text-xl mt-4">
        {site.phone}
      </a>
      <a href="#contact" class="btn-primary text-lg mobile-nav-link">
        Book Appointment
      </a>
    </nav>
  </div>
</header>
