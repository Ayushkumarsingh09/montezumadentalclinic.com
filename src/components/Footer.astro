---
import { site, navLinks } from '../data/site';
---

<footer class="bg-charcoal text-white">
  <div class="section-padding pb-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
        <div class="lg:col-span-1">
          <img src="/images/logo-white.png" alt={site.name} class="h-12 w-auto mb-6 brightness-0 invert opacity-90" width="180" height="48" />
          <p class="text-white/70 leading-relaxed mb-4">{site.tagline}</p>
          <p class="text-white/50 text-sm">Your family's dental home in Montezuma, Iowa.</p>
        </div>

        <div>
          <h3 class="font-display text-lg mb-4 text-amber-light">Quick Links</h3>
          <ul class="space-y-3">
            {
              navLinks.map((link) => (
                <li>
                  <a href={link.href} class="text-white/70 hover:text-white transition-colors text-sm">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h3 class="font-display text-lg mb-4 text-amber-light">Office Hours</h3>
          <ul class="space-y-2">
            {
              site.hours.map((h) => (
                <li class="flex justify-between text-sm">
                  <span class="text-white/70">{h.day}</span>
                  <span class="text-white/90">{h.time}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h3 class="font-display text-lg mb-4 text-amber-light">Contact</h3>
          <address class="not-italic space-y-3 text-sm">
            <p class="text-white/70">
              {site.address.street}<br />
              {site.address.city}, {site.address.state} {site.address.zip}
            </p>
            <p>
              <a href={site.phoneLink} class="text-white hover:text-amber-light transition-colors font-semibold">
                {site.phone}
              </a>
            </p>
            <p>
              <a href={`mailto:${site.email}`} class="text-white/70 hover:text-white transition-colors">
                {site.email}
              </a>
            </p>
          </address>
        </div>
      </div>

      <div class="mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-white/40 text-sm">
          &copy; {new Date().getFullYear()} {site.name}. All rights reserved.
        </p>
        <p class="text-white/40 text-sm">301 S. 4th Street · Montezuma, Iowa</p>
      </div>
    </div>
  </div>
</footer>
