---
import { testimonials } from '../../data/site';
---

<section id="testimonials" class="section-padding bg-sage-50 relative overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="reveal section-label mb-4">Smile Stories</p>
      <h2 class="reveal reveal-delay-1 section-title text-balance mx-auto mb-6">
        Stories From Our Dental Family
      </h2>
      <p class="reveal reveal-delay-2 section-subtitle mx-auto">
        Real words from real patients who trust us with their smiles.
      </p>
    </div>

    <div class="reveal relative max-w-4xl mx-auto">
      <div class="overflow-hidden rounded-4xl">
        <div id="testimonial-track" class="flex transition-transform duration-700 ease-out">
          {
            testimonials.map((t) => (
              <div class="w-full flex-shrink-0 px-4">
                <div class="bg-white rounded-4xl p-10 md:p-14 shadow-card text-center relative">
                  <svg class="w-10 h-10 text-sage-200 mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z"></path>
                  </svg>
                  <span class="inline-block px-4 py-1.5 bg-amber-light/30 text-amber-dark text-xs font-semibold rounded-full mb-6 uppercase tracking-wider">
                    {t.highlight}
                  </span>
                  <blockquote class="font-display text-xl md:text-2xl text-charcoal leading-relaxed mb-8 italic">
                    "{t.quote}"
                  </blockquote>
                  <p class="text-sage-500 font-semibold">{t.author}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div class="flex justify-center gap-2 mt-8">
        {
          testimonials.map((_, i) => (
            <button
              class={`testimonial-dot w-2.5 h-2.5 rounded-full transition-colors ${i === 0 ? 'bg-sage-500' : 'bg-sage-200'}`}
              aria-label={`Go to testimonial ${i + 1}`}
            ></button>
          ))
        }
      </div>
    </div>
  </div>
</section>
