          alt="Comfortable dental experience at Montezuma Dental"
          class="w-full aspect-[4/3] object-cover"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-tr from-sage-500/20 to-transparent"></div>
      </div>

      <div>
        <p class="reveal section-label mb-4">Comfort-First Dentistry</p>
        <h2 class="reveal reveal-delay-1 section-title text-balance mb-6">
