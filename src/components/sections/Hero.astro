---
import { site, heroServices } from '../../data/site';

const icons: Record<string, string> = {
  family: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
  sparkle: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
  emergency: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
};
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="/images/office/hero-1.jpg"
      alt="Montezuma Dental Clinic welcoming office"
      class="w-full h-full object-cover"
      width="1920"
      height="1115"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/80 via-charcoal/50 to-charcoal/20"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal/60 via-transparent to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-8 lg:px-12 pt-32 pb-24 w-full">
    <div class="max-w-3xl">
      <p class="reveal text-amber-light font-semibold text-sm uppercase tracking-[0.25em] mb-6">
        {site.tagline}
      </p>
      <h1 class="reveal reveal-delay-1 font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-white leading-[1.1] mb-6 text-balance">
        Where Montezuma<br />
        <span class="text-amber-light italic">Smiles</span>
      </h1>
      <p class="reveal reveal-delay-2 text-white/85 text-lg md:text-xl leading-relaxed mb-10 max-w-xl">
        Exceptional dentistry with a personal touch. Trusted by families across Montezuma for personalized care, modern treatment, and a comfortable experience every visit.
      </p>
      <div class="reveal reveal-delay-3 flex flex-wrap gap-4 mb-16">
        <a href="#contact" class="btn-amber text-base">Book Appointment</a>
        <a href="#team" class="btn-secondary !bg-white/10 !text-white !border-white/30 hover:!bg-white/20 backdrop-blur-sm">
          Meet Our Team
        </a>
      </div>
    </div>

    <div class="reveal reveal-delay-4 grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      {
        heroServices.map((service) => (
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-4 md:p-5 border border-white/20 hover:bg-white/20 transition-all duration-300 group">
            <svg class="w-6 h-6 text-amber-light mb-3 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icons[service.icon]} />
            </svg>
            <p class="text-white font-semibold text-sm md:text-base">{service.label}</p>
          </div>
        ))
      }
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-float hidden md:block">
    <div class="w-6 h-10 rounded-full border-2 border-white/40 flex justify-center pt-2">
      <div class="w-1 h-2 bg-white/60 rounded-full"></div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-16 bg-cream-50 curve-top"></div>
</section>
