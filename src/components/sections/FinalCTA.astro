---
import { site } from '../../data/site';
---

<section id="final-cta" class="relative overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="/images/office/hero-2.jpg"
      alt="Join the Montezuma Dental family"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-sage-700/95 via-sage-600/90 to-sage-500/85"></div>
  </div>

  <div class="section-padding relative text-center">
    <div class="max-w-3xl mx-auto">
      <p class="reveal text-amber-light font-semibold text-sm uppercase tracking-[0.25em] mb-6">
        Your Community. Your Dentist.
      </p>
      <h2 class="reveal reveal-delay-1 font-display text-3xl md:text-5xl lg:text-6xl text-white leading-tight mb-6 text-balance">
        Join The Montezuma Dental Family
      </h2>
      <p class="reveal reveal-delay-2 text-white/80 text-lg md:text-xl leading-relaxed mb-10 max-w-xl mx-auto">
        Healthy smiles start here. Experience dentistry with a personal touch—where you're treated like family, not a patient number.
      </p>
      <div class="reveal reveal-delay-3 flex flex-wrap justify-center gap-4">
        <a href="#contact" class="btn-amber text-lg !px-10">Book Appointment</a>
        <a href={site.phoneLink} class="btn-secondary !bg-white/10 !text-white !border-white/30 hover:!bg-white/20 backdrop-blur-sm text-lg !px-10">
          Call {site.phone}
        </a>
      </div>
    </div>
  </div>
</section>
