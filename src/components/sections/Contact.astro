---
import { site } from '../../data/site';
---

<section id="contact" class="section-padding bg-cream-50">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="reveal section-label mb-4">Contact Us</p>
      <h2 class="reveal reveal-delay-1 section-title text-balance mx-auto mb-6">
        Visit Your Hometown Dental Home
      </h2>
      <p class="reveal reveal-delay-2 section-subtitle mx-auto">
        We'd love to welcome you. Reach out to schedule an appointment or ask any questions.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
      <div class="reveal space-y-6">
        <div class="bg-white rounded-3xl p-8 shadow-soft">
          <h3 class="font-display text-xl text-charcoal mb-6">Get In Touch</h3>
          <div class="space-y-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-sage-50 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-charcoal mb-1">Our Address</p>
                <p class="text-charcoal-muted text-sm">
                  {site.address.street}<br />
                  {site.address.city}, {site.address.state} {site.address.zip}
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-sage-50 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-charcoal mb-1">Phone</p>
                <a href={site.phoneLink} class="text-sage-500 font-semibold hover:text-sage-600 transition-colors">
                  {site.phone}
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-sage-50 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-charcoal mb-1">Email</p>
                <a href={`mailto:${site.email}`} class="text-sage-500 hover:text-sage-600 transition-colors text-sm">
                  {site.email}
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-3xl p-8 shadow-soft">
          <h3 class="font-display text-xl text-charcoal mb-4">Office Hours</h3>
          <ul class="space-y-3">
            {
              site.hours.map((h) => (
                <li class="flex justify-between text-sm border-b border-cream-200 pb-3 last:border-0 last:pb-0">
                  <span class="text-charcoal-muted">{h.day}</span>
                  <span class="font-semibold text-charcoal">{h.time}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="reveal reveal-delay-2 space-y-6">
        <div class="rounded-3xl overflow-hidden shadow-card h-64 md:h-80">
          <iframe
            src={site.mapEmbed}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Montezuma Dental Clinic location map"
          ></iframe>
        </div>

        <form class="bg-white rounded-3xl p-8 shadow-soft" action={`mailto:${site.email}`} method="GET">
          <h3 class="font-display text-xl text-charcoal mb-6">Request an Appointment</h3>
          <div class="space-y-4">
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-semibold text-charcoal mb-1.5">Name</label>
                <input type="text" id="name" name="subject" placeholder="Your name" required class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 focus:outline-none focus:ring-2 focus:ring-sage-400 focus:border-transparent transition-all text-sm" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold text-charcoal mb-1.5">Phone</label>
                <input type="tel" id="phone" name="body" placeholder="Your phone number" class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 focus:outline-none focus:ring-2 focus:ring-sage-400 focus:border-transparent transition-all text-sm" />
              </div>
            </div>
            <div>
              <label for="message" class="block text-sm font-semibold text-charcoal mb-1.5">Message</label>
              <textarea id="message" name="body" rows="4" placeholder="Tell us about your visit needs..." class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 focus:outline-none focus:ring-2 focus:ring-sage-400 focus:border-transparent transition-all text-sm resize-none"></textarea>
            </div>
            <button type="submit" class="btn-primary w-full">Send Request</button>
            <p class="text-charcoal-muted text-xs text-center">Or call us directly at <a href={site.phoneLink} class="text-sage-500 font-semibold">{site.phone}</a></p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
