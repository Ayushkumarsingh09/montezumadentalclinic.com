---
import { trustCards } from '../../data/site';

const icons: Record<string, string> = {
  heart: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
  users: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
  tech: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  home: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  comfort: 'M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  clock: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
};
---

<section id="why-us" class="section-padding bg-cream-50">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="reveal section-label mb-4">Why Families Choose Us</p>
      <h2 class="reveal reveal-delay-1 section-title text-balance mx-auto">
        Why Families Choose Montezuma Dental
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        trustCards.map((card, i) => (
          <div class={`reveal card-trust group ${['reveal-delay-1', 'reveal-delay-2', 'reveal-delay-3'][i % 3]}`}>
            <div class="w-14 h-14 rounded-2xl bg-sage-50 flex items-center justify-center mb-6 group-hover:bg-sage-100 transition-colors">
              <svg class="w-7 h-7 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icons[card.icon]} />
              </svg>
            </div>
            <h3 class="font-display text-xl text-charcoal mb-3">{card.title}</h3>
            <p class="text-charcoal-muted leading-relaxed text-sm">{card.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
