---
import { site } from '../../data/site';
---

<section id="emergency" class="relative overflow-hidden">
  <div class="absolute inset-0">
    <img src="/images/office/hero-1.jpg" alt="" class="w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-charcoal/85"></div>
  </div>

  <div class="section-padding relative">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="reveal inline-flex items-center gap-2 px-4 py-2 bg-red-500/20 border border-red-400/30 rounded-full text-red-300 text-sm font-semibold mb-6">
            <span class="w-2 h-2 bg-red-400 rounded-full animate-pulse"></span>
            Emergency Dental Care
          </div>
          <h2 class="reveal reveal-delay-1 font-display text-3xl md:text-4xl lg:text-5xl text-white leading-tight mb-6 text-balance">
            Dental Emergency?<br />We're Here to Help.
          </h2>
          <p class="reveal reveal-delay-2 text-white/75 text-lg leading-relaxed mb-8">
            When you're in pain, you need a trusted local team—not a call center. Montezuma Dental provides immediate care for dental emergencies with the compassion and expertise you deserve.
          </p>

          <div class="reveal reveal-delay-3 grid sm:grid-cols-3 gap-4 mb-10">
            {
              [
                { title: 'Fast Response', desc: 'Call us immediately' },
                { title: 'Immediate Help', desc: 'Same-day emergency care' },
                { title: 'Trusted Local Care', desc: 'Your hometown dentist' },
              ].map((item) => (
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-4 border border-white/10">
                  <h3 class="text-white font-semibold mb-1">{item.title}</h3>
                  <p class="text-white/60 text-sm">{item.desc}</p>
                </div>
              ))
            }
          </div>

          <div class="reveal reveal-delay-4 flex flex-wrap gap-4">
            <a href={site.phoneLink} class="btn-amber text-lg !px-8">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              Call {site.phone}
            </a>
          </div>
        </div>

        <div class="reveal bg-white/10 backdrop-blur-md rounded-4xl p-8 md:p-10 border border-white/20">
          <h3 class="font-display text-2xl text-white mb-6">Common Emergencies We Treat</h3>
          <ul class="space-y-4">
            {
              [
                'Severe toothache or dental pain',
                'Knocked-out or broken teeth',
                'Lost fillings or crowns',
                'Swelling or infection',
                'Injury to mouth or jaw',
              ].map((item) => (
                <li class="flex items-center gap-3 text-white/80">
                  <svg class="w-5 h-5 text-amber-light flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                  </svg>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
