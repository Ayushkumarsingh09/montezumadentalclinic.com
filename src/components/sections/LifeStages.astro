---
import { lifeStages } from '../../data/site';
---

<section id="life-stages" class="section-padding bg-cream-50">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="reveal section-label mb-4">For Every Generation</p>
      <h2 class="reveal reveal-delay-1 section-title text-balance mx-auto mb-6">
        Dentistry For Every Stage of Life
      </h2>
      <p class="reveal reveal-delay-2 section-subtitle mx-auto">
        From first tooth to golden years—Montezuma Dental is the dental home for your entire family.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        lifeStages.map((stage, i) => (
          <div class={`reveal group relative rounded-3xl overflow-hidden aspect-[3/4] cursor-default ${['reveal-delay-1', 'reveal-delay-2', 'reveal-delay-3', 'reveal-delay-4'][i]}`}>
            <img
              src={stage.image}
              alt={`Dental care for ${stage.stage}`}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-charcoal/90 via-charcoal/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <span class="inline-block px-3 py-1 bg-amber-warm/90 text-white text-xs font-semibold rounded-full mb-3 uppercase tracking-wider">
                {stage.stage}
              </span>
              <h3 class="font-display text-xl text-white mb-2">{stage.title}</h3>
              <p class="text-white/75 text-sm leading-relaxed">{stage.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
