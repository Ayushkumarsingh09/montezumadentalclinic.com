---
import { site } from '../data/site';
---

<div class="lg:hidden fixed bottom-0 left-0 right-0 z-50 flex shadow-elevated">
  <a
    href={site.phoneLink}
    class="flex-1 flex items-center justify-center gap-2 py-4 bg-sage-600 text-white font-semibold text-sm hover:bg-sage-700 transition-colors"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
    </svg>
    Call Now
  </a>
  <a
    href="#contact"
    class="flex-1 flex items-center justify-center gap-2 py-4 bg-amber-warm text-white font-semibold text-sm hover:bg-amber-dark transition-colors"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
    </svg>
    Book Visit
  </a>
</div>

<div class="lg:hidden h-16"></div>
