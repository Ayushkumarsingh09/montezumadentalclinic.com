---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} | ${site.tagline}`,
  description = 'Montezuma Dental Clinic offers personalized, community-focused dental care in Montezuma, Iowa. Family dentistry, cosmetic care, emergency services, and more.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2D6A6A" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=Source+Sans+3:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.montezumadentalclinic.com" />
    <meta property="og:image" content="/images/office/hero-1.jpg" />
    <link rel="canonical" href="https://www.montezumadentalclinic.com" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Dentist",
      "name": site.name,
      "description": description,
      "url": "https://www.montezumadentalclinic.com",
      "telephone": site.phone,
      "email": site.email,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": site.address.street,
        "addressLocality": site.address.city,
        "addressRegion": site.address.state,
        "postalCode": site.address.zip,
        "addressCountry": "US"
      },
      "openingHoursSpecification": site.hours.map(h => ({
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": h.day,
        "opens": "07:30",
        "closes": "16:00"
      }))
    })} />
  </head>
  <body class="overflow-x-hidden">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <MobileCTA />
    <script src="../scripts/main.ts"></script>
  </body>
</html>
